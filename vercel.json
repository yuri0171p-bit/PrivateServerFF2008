{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/v2.5/dialog/oauth",
      "destination": "/api/oauth_dialog"
    },
    {
      "source": "/api/service-sever/live/ver.php",
      "destination": "/api/ver"
    },
    {
      "source": "/api/service-sever/live/ver",
      "destination": "/api/ver"
    },
    {
      "source": "/oauth/login",
      "destination": "/oauth/login/oauth_login.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
